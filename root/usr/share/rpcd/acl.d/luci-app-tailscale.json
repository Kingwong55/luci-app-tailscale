{
	"luci-app-tailscale": {
		"description": "Grant access to Tailscale configuration",
		"read": {
			"file": {
				"/sbin/ip -s -j ad": [ "exec" ],
				"/usr/bin/ip -s -j ad": [ "exec" ],
				"/sbin/logread -e tailscale": [ "exec" ],
				"/usr/sbin/tailscale status --json": [ "exec" ],
				"/usr/sbin/tailscale version": [ "exec" ],
				"/usr/sbin/tailscale login": [ "exec" ],
				"/usr/sbin/tailscale logout": [ "exec" ],
				"/usr/sbin/tailscale_helper": [ "exec" ],
				"/usr/sbin/tailscale_helper check_update": [ "exec" ],
				"/usr/sbin/tailscale_helper do_update": [ "exec" ]
			},
			"ubus": {
				"service": [ "list" ]
			},
			"uci": [ "tailscale" ]
		},
		"write": {
			"uci": [ "tailscale" ]
		}
	}
}
